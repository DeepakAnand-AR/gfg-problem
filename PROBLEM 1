import java.util.Scanner;
public class WheatDiseaseLabelScore {
public static int calculateDiseaseScore(String diseaseName) {
int score = 0;
for (int i = 0; i < diseaseName.length() - 1; i++) {
score += Math.abs(diseaseName.charAt(i) - diseaseName.charAt(i + 1));
 }
 return score;
    }
public static void main(String[] args) {
Scanner sc = new Scanner(System.in);
System.out.print("Enter Wheat Disease Name: ");
String disease = sc.nextLine();
int score = calculateDiseaseScore(disease);
System.out.println("Disease Feature Score: " + score);
    }
}
